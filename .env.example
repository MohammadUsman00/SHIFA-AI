# Copy this file to `.env.local` and fill in real values (never commit `.env` or `.env.local`).

GEMINI_API_KEY=
EXA_API_KEY=
APIFY_API_TOKEN=
NEXT_PUBLIC_CONVEX_URL=

# Set automatically when you run `npx convex dev` (dev deployment), e.g. dev:your-project-name
# CONVEX_DEPLOYMENT=

# Optional: distributed rate limiting (recommended on Vercel — see docs/PRODUCTION.md)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional tuning (defaults: 30 requests / 60s per client key)
# RATE_LIMIT_MAX_REQUESTS=30
# RATE_LIMIT_WINDOW_MS=60000

# Local only: disable all API rate limits
# RATE_LIMIT_DISABLED=true
